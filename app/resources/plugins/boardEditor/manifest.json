{
  "manifest_ver": "1.0",
  "id": "boardEditor",
  "name": "Board Editor",
  "author": {
    "name": "Icestudio"
  },
  "version": "1.0",
  "launchAtStartup": false,
  "icon": "icon.svg",
  "multipleInstances": false,
  "gui": {
    "type": "embedded",
    "windowed": "true",
    "layout": ["boardEditor.html"],
    "style": ["css/style.css"],
    "styleThemed": {
      "dark": ["css/dark/dark.css"],
      "light": ["css/light/light.css"]
    },
    "styleHost": ["css/host.css"],
    "scripts": ["js/events.js", "js/pcfImport.js", "js/boardEditor.js"],
    "views": [],
    "width": "980px",
    "height": "640px",
    "resizable": true,
    "title": true,
    "minimizable": true
  }
}
