{
  "manifest_ver": "1.0",
  "id": "setupWizard",
  "name": "Setup Wizard",
  "author": {
    "name": "Icestudio"
  },
  "version": "1.0",
  "launchAtStartup": false,
  "icon": "icon.svg",
  "multipleInstances": false,
  "gui": {
    "type": "embedded",
    "windowed": "true",
    "title": true,
    "layout": ["wizard.html"],
    "style": ["css/style.css"],
    "styleThemed": {
      "dark": ["css/dark/dark.css"],
      "light": ["css/light/light.css"]
    },
    "styleHost": ["css/host.css"],
    "scripts": ["js/wizard.js"],
    "views": []
  }
}
