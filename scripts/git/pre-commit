#!/bin/bash
# Icestudio automatic format and linter script before git commit
# ==============================================================
# Install: Copy this file in .git/hooks maintain the name and do it
#          executable if not is it.
# Author: Carlos Venegas -> @cavearr at github/X
# Pre-commit hook: Run Prettier & JSHint before committing
# Compatible with Windows (Git Bash), Linux, and macOS

CYAN_BRIGHT='\033[1;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
ERROR_ICON="⛔"
SUCCESS_ICON="✅"
WARNING_ICON="⚠️"
ADD_ICON="📥"
ADDED_FILES_ICON="➕"
INFO_ICON="ℹ"

# Create a temp directory in .git/tmp/ (cross-platform)
TEMP_DIR=".git/tmp"
mkdir -p "$TEMP_DIR"
MODIFIED_FILES="$TEMP_DIR/prettier-modified.txt"

# Helper file for console box messages
box_message() {
    local color=$1
    local icon=$2
    local message=$3

    local length=${#message}
    local border=$(printf '%*s' $((length + 7)) '' | tr ' ' '-')

    echo -e "${color}"
    echo -e "+${border}+"
    echo -e "|  ${icon} ${message}  |"
    echo -e "+${border}+"
    echo -e "${NC}"
}

# Ensure script stops on first error
set -e

# Handle Ctrl+C properly (exit cleanly)
cleanup() {
    printf "\r${NC}  \n" # Reset colors and clean the line
    rm -f "$MODIFIED_FILES" 2>/dev/null || del "$MODIFIED_FILES" 2>/dev/null
    exit 1
}
trap cleanup SIGINT

# Spinner function
spin() {
  spin_chars='-\|/'
  i=0
  while kill -0 "$1" 2>/dev/null; do
    i=$(( (i+1) %4 ))
    printf "\r${YELLOW} ${spin_chars:$i:1} Running Prettier...${NC}"
    sleep 0.1
  done
}

# Step 0: Clean and prepare commit. Some OSs include dependencies only for it and this
#         could break the build for other OSs (only affects OSX)
box_message "\n$YELLOW" "$WARNING_ICON" "Preparing package.json..."
if [ -n "$COMSPEC" ]; then
        # Windows CMD
        box_message "$GREEN" "$SUCCESS_ICON" "Nothing to do..."
elif [ -n "$PSModulePath" ]; then
        # PowerShell
        box_message "$GREEN" "$SUCCESS_ICON" "Nothing to do..."
else
        # Linux/macOS/Git Bash
        if ! npm run preparePackageJson; then
          box_message "$RED" "$ERROR_ICON" "Error working on package.json standardization"
          exit 1
        fi

        # Check if package.json was modified before adding it to the commit
        if ! git diff --quiet package.json; then
          git add package.json
          box_message "$GREEN" "$SUCCESS_ICON" "package.json was modified and added to the commit."
        else
          box_message "$GRAY" "$INFO_ICON" "No changes detected in package.json. Skipping git add."
        fi
fi

## Step 1: Run PrettierBot with Spinner
box_message "$YELLOW" "$WARNING_ICON" "Reformatting code with Prettier..."
npm run prettierBot > "$MODIFIED_FILES" & # Run Prettier in the background
PRETTIER_PID=$!

# Start spinner
spin $PRETTIER_PID

# Wait for Prettier to finish
wait $PRETTIER_PID
PRETTIER_EXIT_CODE=$?

# Ensure spinner disappears
printf "\r${NC}  \n"

if [[ $PRETTIER_EXIT_CODE -ne 0 ]]; then
    box_message "$RED" "$ERROR_ICON" "Prettier failed! Check manually."
    cleanup
    exit 1
else
    box_message "$GREEN" "$SUCCESS_ICON" "Code reformatted with Prettier."
fi

## Step 2: Filter modified files, discarding lines that contain prettier message "(unchanged)"
grep -v "(unchanged)" "$MODIFIED_FILES" | awk '{print $1}' > "$MODIFIED_FILES.tmp" && mv "$MODIFIED_FILES.tmp" "$MODIFIED_FILES"

## Step 3: Show the user modified files
if [[ ! -s "$MODIFIED_FILES" ]]; then
    box_message "$GRAY" "$INFO_ICON" "No files were modified by Prettier."
else
    box_message "$CYAN_BRIGHT" "$ADD_ICON" "Adding formatted files to commit..."
    while IFS= read -r file; do
        if [[ -f "$file" ]]; then
            git add "$file"
        fi
    done < "$MODIFIED_FILES"

    echo -e "${CYAN_BRIGHT}${ADDED_FILES_ICON} The following files were formatted and added:${NC}"
    cat "$MODIFIED_FILES" | awk '{print "  - "$0}'
fi

## Cleanup temp files
rm -f "$MODIFIED_FILES" 2>/dev/null || del "$MODIFIED_FILES" 2>/dev/null

## Clean failed file flag if exists
if [ -f "pre-commit.failed" ]; then
    rm pre-commit.failed 2>/dev/null || del pre-commit.failed
fi

## Step 4: Run JSHint, and if not passed break the commit
box_message "\n$YELLOW" "$WARNING_ICON" "Running linter check..."
if ! npm run jshint --silent; then
    box_message "$RED" "$ERROR_ICON" "Linting failed! Fix issues before committing."
    if [ -n "$COMSPEC" ]; then
        # Windows CMD
        echo. > pre-commit.failed
    elif [ -n "$PSModulePath" ]; then
        # PowerShell
        New-Item -Path "pre-commit.failed" -ItemType File -Force | Out-Null
    else
        # Linux/macOS/Git Bash
        touch pre-commit.failed
    fi
    exit 1
fi

## Step 5: All checks passed, proceed with commit
box_message "$GREEN" "$SUCCESS_ICON" "All checks passed. Proceeding with commit."
exit 0


